# General runtime settings
ASHARE_ENVIRONMENT=development
ASHARE_LOG_LEVEL=INFO
ASHARE_DATABASE_URL=sqlite:///data/ashare_review.sqlite3
ASHARE_COLLECTION_TIMEOUT_SECONDS=10
ASHARE_COLLECTION_MINIMUM_INTERVAL_SECONDS=1
ASHARE_COLLECTION_MAX_ATTEMPTS=3
ASHARE_POOL_MIN_PREVIOUS_DAY_AMOUNT_CNY=500000000
ASHARE_POOL_MAX_CANDIDATES=5
ASHARE_POOL_INCLUDE_CHINEXT=false

# Features remain disabled until their sources and credentials are approved.
ASHARE_AI_ENABLED=false
ASHARE_EMAIL_ENABLED=false

# Provide real values only in an untracked .env file.
ASHARE_OPENAI_API_KEY=
ASHARE_SMTP_HOST=
ASHARE_SMTP_PORT=587
ASHARE_SMTP_USE_SSL=false
ASHARE_SMTP_USERNAME=
ASHARE_SMTP_PASSWORD=
ASHARE_SMTP_RECIPIENTS=
