# Python bytecode and tooling caches
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pytype/
.coverage
.coverage.*
htmlcov/

# Virtual environments and build artifacts
.venv/
venv/
env/
build/
dist/
