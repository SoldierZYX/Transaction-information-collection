# Secrets: keep the shareable template only
.env
.env.*
!.env.example

# Local runtime artifacts
data/*
!data/.gitkeep
reports/*
!reports/.gitkeep
logs/
*.db
*.sqlite
*.sqlite3

# Notebooks and local IDE settings
.ipynb_checkpoints/
.idea/
.vscode/

# Operating system files
Thumbs.db
Desktop.ini
.DS_Store
